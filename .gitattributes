*.jpg filter=lfs diff=lfs merge=lfs -text
*.golden text eol=lf

# FreeCAD project files are deflate zips containing OCCT binary
# BRep entries. Mark them binary so git skips CRLF normalisation,
# textconv diff attempts (which would be noise), and merges.
*.FCStd binary
*.fcstd binary

# SolidWorks parts/assemblies are OLE compound binaries; same rationale.
*.sldprt binary
*.SLDPRT binary
*.sldasm binary
*.SLDASM binary
