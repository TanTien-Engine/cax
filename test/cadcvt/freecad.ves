var node0 = ::blueprint::nodes::camera3d::Camera3d()

node0.cam.position.set(-0.035309201831893, -0.31726515389588, 0.25840701518655)
node0.cam.yaw = -90.2
node0.cam.pitch = 44.6
node0.cam.zoom = 45
node0.cam.update_vectors()
node0.speed = 0.097699411213398

_editor.add_node(node0, 537.95018571588, -34.75814028784)

var node1 = ::blueprint::nodes::subgraph::Subgraph()
node1.load_from_file(_editor, "../../assets/blueprints/render/draw_mesh.ves")
node1.set_prop_value("no_bg", false)

_editor.add_node(node1, 749.52599052345, 149.08054285977)

var node2 = ::brepkit::nodes::to_mesh::ToMesh()

_editor.add_node(node2, 210.13432009961, 170.93279498784)

var node3 = ::blueprint::nodes::cache::Cache()
node3.query_param("disable").value = false

_editor.add_node(node3, 392.18895050427, 211.79090897199)

var node4 = ::cadcvt::nodes::load_freecad::LoadFreecad()
node4.query_param("path").value = "PartDesignExample.FCStd"
node4.query_param("unit_scale").value = 0.001
node4.query_param("strict").value = false

_editor.add_node(node4, 29.22809917355, 135.62727272727)

var node5 = ::blueprint::nodes::cache::Cache()
node5.query_param("disable").value = false

_editor.add_node(node5, 397.97407447121, 120.3305785124)

// Transparent group: a second ToMesh + cache for the parts whose
// MaterialIR.transparency > 0 (e.g. cylinder shells). Fed into
// draw_mesh's geos_transparent input so they render in the blend /
// depth-mask-off pass after the opaque parts.
var node6 = ::brepkit::nodes::to_mesh::ToMesh()

_editor.add_node(node6, 210.13432009961, 380.93279498784)

var node7 = ::blueprint::nodes::cache::Cache()
node7.query_param("disable").value = false

_editor.add_node(node7, 392.18895050427, 420.79090897199)

// Cache for the transparent parts' edges (baked with each part's alpha).
var node8 = ::blueprint::nodes::cache::Cache()
node8.query_param("disable").value = false

_editor.add_node(node8, 392.18895050427, 520.79090897199)

// Opaque group -> main surface + edges.
Blueprint.connect(node4, "shape_opaque", node2, "shape")
Blueprint.connect(node2, "edges", node5, "var")
Blueprint.connect(node2, "va", node3, "var")
Blueprint.connect(node3, "var", node1, "geos")
Blueprint.connect(node0, "this", node1, "view_cam")
Blueprint.connect(node5, "var", node1, "edges")

// Transparent group -> x-ray surface pass + x-ray edge pass. Each
// part's alpha (1 - transparency) is zipped into ToMesh and baked
// per-vertex for both the faces (va) and the topological edges.
Blueprint.connect(node4, "shape_transparent", node6, "shape")
Blueprint.connect(node4, "transparent_alphas", node6, "alpha")
Blueprint.connect(node6, "va", node7, "var")
Blueprint.connect(node7, "var", node1, "geos_transparent")
Blueprint.connect(node6, "edges", node8, "var")
Blueprint.connect(node8, "var", node1, "edges_transparent")
