<?xml version="1.0" encoding="utf-8"?>
<!--
  Sister fixture to pad_box.xml: identical 20 x 10 mm rectangle
  sketch, but pocketed 5 mm instead of padded. The reader maps
  PartDesign::Pocket -> FeatType::CutExtrude and inverts the
  flip_direction relative to Pad (Pocket cuts INTO material, Pad
  extrudes along the sketch normal), so even with Reversed=false
  in the XML the IR's flip=1.

  Authored to be a one-token delta from pad_box.xml -- a regression
  that affects the shared sketch / extrude path lights up both
  fixtures, a regression that only affects Pocket lights up only
  this one. That dichotomy is what locates the bug.
-->
<Document SchemaVersion="4">
  <Objects Count="3">
    <Object name="Body" type="PartDesign::Body" />
    <Object name="Sketch" type="Sketcher::SketchObject" />
    <Object name="Pocket" type="PartDesign::Pocket" />
  </Objects>
  <ObjectData Count="3">

    <Object name="Body">
      <Properties Count="1">
        <Property name="Group" type="App::PropertyLinkList">
          <LinkList count="2">
            <Link value="Sketch" />
            <Link value="Pocket" />
          </LinkList>
        </Property>
      </Properties>
    </Object>

    <Object name="Sketch">
      <Properties Count="3">
        <Property name="Placement" type="App::PropertyPlacement">
          <PropertyPlacement Px="0" Py="0" Pz="0" Q0="0" Q1="0" Q2="0" Q3="1" />
        </Property>
        <Property name="Geometry" type="Sketcher::PropertyGeometryList">
          <GeometryList count="4">
            <Geometry type="Part::GeomLineSegment">
              <LineSegment StartX="0"  StartY="0"  EndX="20" EndY="0" />
            </Geometry>
            <Geometry type="Part::GeomLineSegment">
              <LineSegment StartX="20" StartY="0"  EndX="20" EndY="10" />
            </Geometry>
            <Geometry type="Part::GeomLineSegment">
              <LineSegment StartX="20" StartY="10" EndX="0"  EndY="10" />
            </Geometry>
            <Geometry type="Part::GeomLineSegment">
              <LineSegment StartX="0"  StartY="10" EndX="0"  EndY="0" />
            </Geometry>
          </GeometryList>
        </Property>
        <Property name="Constraints" type="Sketcher::PropertyConstraintList">
          <ConstraintList count="6">
            <Constraint Type="1" First="0" FirstPos="2" Second="1" SecondPos="1" Value="0" />
            <Constraint Type="1" First="1" FirstPos="2" Second="2" SecondPos="1" Value="0" />
            <Constraint Type="1" First="2" FirstPos="2" Second="3" SecondPos="1" Value="0" />
            <Constraint Type="1" First="3" FirstPos="2" Second="0" SecondPos="1" Value="0" />
            <Constraint Type="6" First="0" FirstPos="0" Second="-1" SecondPos="0" Value="20" />
            <Constraint Type="8" First="1" FirstPos="0" Second="-1" SecondPos="0" Value="10" />
          </ConstraintList>
        </Property>
      </Properties>
    </Object>

    <Object name="Pocket">
      <Properties Count="3">
        <Property name="Profile" type="App::PropertyLinkSub">
          <LinkSub value="Sketch" count="0" />
        </Property>
        <Property name="Length" type="App::PropertyLength">
          <Float value="5" />
        </Property>
        <Property name="Type" type="App::PropertyEnumeration">
          <Integer value="0" />
        </Property>
      </Properties>
    </Object>

  </ObjectData>
</Document>
