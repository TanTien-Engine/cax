<?xml version="1.0" encoding="utf-8"?>
<!--
  A 5 mm-radius circle padded 2 mm into a thin disc. Picks up
  two reader paths the rectangle fixtures don't touch:

    - Part::GeomCircle in ParseSketchGeometry (separate branch
      from GeomLineSegment), emitting a 3-param Circle geo;
    - FreeCAD Constraint Type="11" -> SkConsType::CircleRadius,
      which is a length-type constraint and therefore must be
      scaled by m_unit_scale (the same code path the
      Distance/DistanceY fix added a witness for; circle radii
      are a separate witness for the same bug class, since the
      mapping table treats them differently).

  Constraint count is 1 -- no coincidents needed for a closed
  curve. The b-ref is intentionally absent (Second omitted), so
  the golden pins the default 4294967295 sentinel.
-->
<Document SchemaVersion="4">
  <Objects Count="3">
    <Object name="Body" type="PartDesign::Body" />
    <Object name="Sketch" type="Sketcher::SketchObject" />
    <Object name="Pad" type="PartDesign::Pad" />
  </Objects>
  <ObjectData Count="3">

    <Object name="Body">
      <Properties Count="1">
        <Property name="Group" type="App::PropertyLinkList">
          <LinkList count="2">
            <Link value="Sketch" />
            <Link value="Pad" />
          </LinkList>
        </Property>
      </Properties>
    </Object>

    <Object name="Sketch">
      <Properties Count="3">
        <Property name="Placement" type="App::PropertyPlacement">
          <PropertyPlacement Px="0" Py="0" Pz="0" Q0="0" Q1="0" Q2="0" Q3="1" />
        </Property>
        <Property name="Geometry" type="Sketcher::PropertyGeometryList">
          <GeometryList count="1">
            <Geometry type="Part::GeomCircle">
              <Circle CenterX="0" CenterY="0" Radius="5" />
            </Geometry>
          </GeometryList>
        </Property>
        <Property name="Constraints" type="Sketcher::PropertyConstraintList">
          <ConstraintList count="1">
            <Constraint Type="11" First="0" FirstPos="0" Value="5" />
          </ConstraintList>
        </Property>
      </Properties>
    </Object>

    <Object name="Pad">
      <Properties Count="3">
        <Property name="Profile" type="App::PropertyLinkSub">
          <LinkSub value="Sketch" count="0" />
        </Property>
        <Property name="Length" type="App::PropertyLength">
          <Float value="2" />
        </Property>
        <Property name="Type" type="App::PropertyEnumeration">
          <Integer value="0" />
        </Property>
      </Properties>
    </Object>

  </ObjectData>
</Document>
