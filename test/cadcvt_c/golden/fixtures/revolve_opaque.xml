  <Objects Count="3">
    <Object name="Body" type="PartDesign::Body" />
    <Object name="Sketch" type="Sketcher::SketchObject" />
    <Object name="Revolution" type="PartDesign::Revolution" />
  </Objects>
  <ObjectData Count="3">

    <Object name="Body">
      <Properties Count="1">
        <Property name="Group" type="App::PropertyLinkList">
          <LinkList count="2">
