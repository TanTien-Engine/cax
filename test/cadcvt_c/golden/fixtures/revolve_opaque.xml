<?xml version="1.0" encoding="utf-8"?>
<!--
  PartDesign::Revolution is now typed in the reader and emits a
  FeatPayloadRevolve / FeatType::BossRevolve. The .ir.golden line
  should read `revolve sketch_id=2 axis_o=(0.000,0.000,0.000)
  axis_d=(0.000,0.000,1.000) angle=6.283 flip=0` (defaults: no
  ReferenceAxis -> world Z through origin; Angle 360deg -> 2*PI).

  The sketch is a single line off-axis -- a degenerate profile,
  but the IR snapshot only records the parsed parameters; the
  geo-layer test is what would catch a real revolve failure. For
  proper revolve coverage add a separate fixture with a closed
  profile and an explicit ReferenceAxis link.
-->
<Document SchemaVersion="4">
  <Objects Count="3">
    <Object name="Body" type="PartDesign::Body" />
    <Object name="Sketch" type="Sketcher::SketchObject" />
    <Object name="Revolution" type="PartDesign::Revolution" />
  </Objects>
  <ObjectData Count="3">

    <Object name="Body">
      <Properties Count="1">
        <Property name="Group" type="App::PropertyLinkList">
          <LinkList count="2">
            <Link value="Sketch" />
            <Link value="Revolution" />
          </LinkList>
        </Property>
      </Properties>
    </Object>

    <Object name="Sketch">
      <Properties Count="2">
        <Property name="Placement" type="App::PropertyPlacement">
          <PropertyPlacement Px="0" Py="0" Pz="0" Q0="0" Q1="0" Q2="0" Q3="1" />
        </Property>
        <Property name="Geometry" type="Sketcher::PropertyGeometryList">
          <GeometryList count="1">
            <Geometry type="Part::GeomLineSegment">
              <LineSegment StartX="10" StartY="0" EndX="10" EndY="20" />
            </Geometry>
          </GeometryList>
        </Property>
      </Properties>
    </Object>

    <Object name="Revolution">
      <Properties Count="2">
        <Property name="Profile" type="App::PropertyLinkSub">
          <LinkSub value="Sketch" count="0" />
        </Property>
        <Property name="Angle" type="App::PropertyAngle">
          <Float value="360" />
        </Property>
      </Properties>
    </Object>

  </ObjectData>
</Document>
